{
  "name": "ah-ui",
  "version": "1.0.0",
  "description": "基于 Element Plus 封装的业务组件库",
  "type": "module",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "exports": {
    ".": {
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./es/*": {
      "import": "./es/*"
    }
  },
  "files": [
    "es",
    "lib"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "vue": "^3.2.0",
    "element-plus": "^2.3.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "element-plus": "^2.3.14",
    "sass": "^1.69.5",
    "typescript": "^5.3.2",
    "unplugin-vue-components": "^0.26.0",
    "unplugin-auto-import": "^0.17.2",
    "vite": "^5.0.8",
    "vitepress": "^1.0.0-rc.44",
    "vue": "^3.3.11",
    "vue-tsc": "^1.8.25"
  },
  "keywords": [
    "vue",
    "element-plus",
    "component-library",
    "ui-components"
  ],
  "author": "",
  "license": "MIT"
}
